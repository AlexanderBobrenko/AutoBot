###############################################
# Copy to .env and set real values locally.
# DO NOT commit your .env to GitHub.
###############################################

# Telegram bot token (required)
TOKEN="123456789:YOUR_TELEGRAM_BOT_TOKEN"

# Comma-separated Telegram user IDs of bot admins (optional)
# Example: "123456789,987654321"
ADMIN_IDS="123456789"

# Exchange rates: how many RUB for 1 USD/EUR (optional)
USD_RUB_RATE="90.0"
EUR_RUB_RATE="100.0"

# Google Sheets: service account JSON (optional, needed for /connect_google)
# Paste the full JSON string into this variable in your hosting environment.
# Locally you can also put credentials.json file into the project root.
GOOGLE_CREDENTIALS_JSON=""

